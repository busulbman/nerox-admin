[debug] [2026-07-06T09:59:43.187Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/nerox-restaurant-system/rulesets {"name":"projects/nerox-restaurant-system/rulesets/42348927-b11f-4743-9994-e84d2f1e2054","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // ─── Helper functions ───────────────────────────────────────────────────────\n\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function userDoc() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    function role() {\n      return signedIn() ? userDoc().role : null;\n    }\n\n    function userRestaurantId() {\n      return signedIn() ? userDoc().restaurantId : null;\n    }\n\n    function isAdmin(rid) {\n      return signedIn() && role() == 'admin' && userRestaurantId() == rid;\n    }\n\n    function isWaiter(rid) {\n      return signedIn() && role() == 'waiter' && userRestaurantId() == rid;\n    }\n\n    function isStaff(rid) {\n      return isAdmin(rid) || isWaiter(rid);\n    }\n\n    function restaurantPath(rid) {\n      return /databases/$(database)/documents/restaurants/$(rid);\n    }\n\n    function restaurantExists(rid) {\n      return exists(restaurantPath(rid));\n    }\n\n    function restaurantDoc(rid) {\n      return get(restaurantPath(rid)).data;\n    }\n\n    function isRestaurantActive(rid) {\n      let status = get(restaurantPath(rid)).data.status;\n      return status == null || status == 'active';\n    }\n\n    function isSubscriptionValid(rid) {\n      let data = get(restaurantPath(rid)).data;\n      // If subscriptionExpiresAt field doesn't exist or is null, allow access\n      let expires = data.subscriptionExpiresAt;\n      return !('subscriptionExpiresAt' in data)\n        || expires == null\n        || (expires is timestamp && expires >= request.time)\n        || (expires is int && expires >= request.time.toMillis());\n    }\n\n    function restaurantAllowsPublicAccess(rid) {\n      return exists(restaurantPath(rid))\n        && isRestaurantActive(rid)\n        && isSubscriptionValid(rid);\n    }\n\n    function waiterCanAcceptCall(rid) {\n      return isWaiter(rid)\n        && resource.data.durum == 'bekliyor'\n        && request.resource.data.durum == 'kabul edildi'\n        && request.resource.data.status == 'accepted'\n        && request.resource.data.waiterId == request.auth.uid\n        && request.resource.data.waiterName is string\n        && isOptionalPhotoUrl(request.resource.data.waiterPhotoUrl)\n        && isOptionalWaiterAverageRating(request.resource.data.waiterAverageRating)\n        && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['durum', 'status', 'waiterId', 'waiterName', 'waiterPhotoUrl', 'waiterAverageRating', 'acceptedAt']);\n    }\n\n    function waiterCanCompleteOwnCall(rid) {\n      return isWaiter(rid)\n        && resource.data.durum == 'kabul edildi'\n        && resource.data.waiterId == request.auth.uid\n        && request.resource.data.durum == 'tamamlandı'\n        && request.resource.data.status == 'completed'\n        && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['durum', 'status', 'completedAt', 'resolvedAt', 'completedById', 'completedByName', 'completedByRole']);\n    }\n\n    function waiterCanDeliverReadyOrder(rid) {\n      return isWaiter(rid)\n        && resource.data.kitchenStatus == 'ready'\n        && request.resource.data.kitchenStatus == 'delivered'\n        && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['kitchenStatus', 'deliveredAt', 'kitchenUpdatedById', 'kitchenUpdatedByName']);\n    }\n\n    function waiterCanCreateOrder(rid) {\n      return isWaiter(rid)\n        && request.resource.data.restaurantId == rid\n        && request.resource.data.tip == 'sipariş'\n        && request.resource.data.durum == 'kabul edildi'\n        && request.resource.data.status == 'accepted'\n        && request.resource.data.waiterId == request.auth.uid\n        && request.resource.data.waiterName is string\n        && isOptionalPhotoUrl(request.resource.data.waiterPhotoUrl)\n        && isOptionalWaiterAverageRating(request.resource.data.waiterAverageRating)\n        && request.resource.data.createdByRole == 'waiter'\n        && request.resource.data.createdById == request.auth.uid\n        && request.resource.data.items is list\n        && request.resource.data.items.size() > 0\n        && isNonNegativeNumber(request.resource.data.totalPrice);\n    }\n\n    function isNonNegativeNumber(value) {\n      return (value is int || value is float) && value >= 0;\n    }\n\n    function isOptionalPhotoUrl(value) {\n      return value == null || value is string;\n    }\n\n    function isOptionalWaiterAverageRating(value) {\n      return value == null || (\n        (value is int || value is float)\n        && value >= 0\n        && value <= 5\n      );\n    }\n\n    function publicCallTargetsLiveTableSession(rid) {\n      return request.resource.data.restaurantId == rid\n        && request.resource.data.tableId is string\n        && request.resource.data.tableId.size() > 0\n        && request.resource.data.tableNumber is int\n        && request.resource.data.sessionId is string\n        && request.resource.data.sessionId.size() > 0\n        && exists(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId))\n        && get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId)).data.number == request.resource.data.tableNumber\n        && get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId)).data.sessionId == request.resource.data.sessionId\n        && get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId)).data.status in ['aktif', 'çağrı var', 'hesap istendi'];\n    }\n\n    function validPublicCallBase(rid) {\n      return restaurantAllowsPublicAccess(rid)\n        && publicCallTargetsLiveTableSession(rid)\n        && request.resource.data.durum == 'bekliyor'\n        && request.resource.data.status == 'open'\n        && request.resource.data.waiterId == null\n        && request.resource.data.waiterName == null\n        && request.resource.data.waiterPhotoUrl == null\n        && request.resource.data.waiterAverageRating == null\n        && request.resource.data.note is string;\n    }\n\n    function validPublicOrderCall(rid) {\n      return validPublicCallBase(rid)\n        && request.resource.data.tip == 'sipariş'\n        && request.resource.data.customerName is string\n        && request.resource.data.customerName.size() > 0\n        && request.resource.data.items is list\n        && request.resource.data.items.size() > 0\n        && request.resource.data.groupedByCustomer is map\n        && request.resource.data.groupedByCustomer.keys().size() > 0\n        && isNonNegativeNumber(request.resource.data.totalPrice)\n        && request.resource.data.keys().hasAll([\n          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',\n          'durum', 'status', 'customerName', 'createdAt', 'waiterId',\n          'waiterName', 'waiterPhotoUrl', 'waiterAverageRating', 'note',\n          'items', 'totalPrice', 'groupedByCustomer'\n        ])\n        && request.resource.data.keys().hasOnly([\n          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',\n          'durum', 'status', 'customerName', 'createdAt', 'waiterId',\n          'waiterName', 'waiterPhotoUrl', 'waiterAverageRating', 'note',\n          'items', 'totalPrice', 'groupedByCustomer', 'customerId',\n          'customerPhone', 'loyaltyPreview'\n        ]);\n    }\n\n    function validPublicServiceCall(rid) {\n      return validPublicCallBase(rid)\n        && request.resource.data.tip in ['yardım', 'hesap']\n        && (request.resource.data.customerName == null || request.resource.data.customerName is string)\n        && request.resource.data.keys().hasAll([\n          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',\n          'durum', 'status', 'customerName', 'createdAt', 'waiterId',\n          'waiterName', 'waiterPhotoUrl', 'waiterAverageRating', 'note'\n        ])\n        && request.resource.data.keys().hasOnly([\n          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',\n          'durum', 'status', 'customerName', 'createdAt', 'waiterId',\n          'waiterName', 'waiterPhotoUrl', 'waiterAverageRating', 'note'\n        ]);\n    }\n\n    function validPublicCustomerCreate(rid) {\n      return restaurantAllowsPublicAccess(rid)\n        && request.resource.data.name is string\n        && request.resource.data.name.size() > 0\n        && request.resource.data.phone is string\n        && request.resource.data.phone.size() > 0\n        && (\n          !('email' in request.resource.data)\n          || request.resource.data.email == null\n          || request.resource.data.email is string\n        )\n        && request.resource.data.loyaltyEnabled == true\n        && request.resource.data.points == 0\n        && request.resource.data.totalOrders == 0\n        && request.resource.data.totalSpent == 0\n        && request.resource.data.keys().hasAll([\n          'name', 'phone', 'loyaltyEnabled', 'points', 'totalOrders',\n          'totalSpent', 'createdAt', 'updatedAt'\n        ])\n        && request.resource.data.keys().hasOnly([\n          'name', 'phone', 'email', 'loyaltyEnabled', 'points', 'totalOrders',\n          'totalSpent', 'createdAt', 'updatedAt'\n        ]);\n    }\n\n    // ─── Users collection ───────────────────────────────────────────────────────\n\n    match /users/{uid} {\n      // Users can read their own profile\n      allow read: if signedIn() && request.auth.uid == uid;\n\n      // Admin can read/write users in their restaurant\n      allow read: if signedIn() && isAdmin(resource.data.restaurantId);\n      allow write: if signedIn() && isAdmin(request.resource.data.restaurantId);\n\n      // Waiters can read active waiter leaderboard entries from their restaurant\n      allow read: if signedIn()\n        && role() == 'waiter'\n        && resource.data.role == 'waiter'\n        && resource.data.active == true\n        && resource.data.restaurantId == userRestaurantId();\n\n      // Allow user to update their own presence fields\n      allow update: if signedIn() && request.auth.uid == uid\n        && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['isOnline', 'lastSeen']);\n\n      // Waiters can update only their own display profile\n      allow update: if signedIn()\n        && request.auth.uid == uid\n        && role() == 'waiter'\n        && resource.data.role == 'waiter'\n        && resource.data.restaurantId == userRestaurantId()\n        && request.resource.data.name is string\n        && request.resource.data.name.size() > 0\n        && isOptionalPhotoUrl(request.resource.data.photoUrl)\n        && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['name', 'photoUrl', 'updatedAt']);\n\n      // Allow waiter to increment only their own completed call counter\n      allow update: if signedIn()\n        && request.auth.uid == uid\n        && role() == 'waiter'\n        && resource.data.role == 'waiter'\n        && resource.data.restaurantId == userRestaurantId()\n        && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['totalCalls', 'completedCalls'])\n        && request.resource.data.totalCalls is int\n        && request.resource.data.totalCalls == ((resource.data.totalCalls is int ? resource.data.totalCalls : 0) + 1)\n        && (\n          !('completedCalls' in request.resource.data)\n          || (\n            request.resource.data.completedCalls is int\n            && request.resource.data.completedCalls == ((resource.data.completedCalls is int ? resource.data.completedCalls : 0) + 1)\n          )\n        );\n    }\n\n    // ─── Restaurant data ────────────────────────────────────────────────────────\n\n    match /restaurants/{rid} {\n      allow get, list: if isStaff(rid);\n      allow create: if isAdmin(rid);\n      allow update: if isAdmin(rid);\n      allow delete: if isAdmin(rid);\n\n      // ── Categories & Products (Menu) ──────────────────────────────────────────\n\n      match /categories/{catId} {\n        // Staff can always read their own menu\n        allow read: if isStaff(rid) || restaurantAllowsPublicAccess(rid);\n        // Only admin can modify\n        allow write: if isAdmin(rid);\n      }\n\n      match /products/{prodId} {\n        // Staff can always read their own menu\n        allow read: if isStaff(rid) || restaurantAllowsPublicAccess(rid);\n        // Only admin can modify\n        allow write: if isAdmin(rid);\n      }\n\n      // ── Loyalty Campaigns ─────────────────────────────────────────────────────\n\n      match /loyaltyCampaigns/{campaignId} {\n        allow read: if isAdmin(rid) || (\n          restaurantAllowsPublicAccess(rid)\n          && resource.data.active == true\n        );\n        allow write: if isAdmin(rid);\n      }\n\n      // ── Customers ─────────────────────────────────────────────────────────────\n\n      match /customers/{customerId} {\n        allow read: if isAdmin(rid);\n        allow write: if isAdmin(rid);\n        allow create: if validPublicCustomerCreate(rid);\n      }\n\n      // ── Tables ────────────────────────────────────────────────────────────────\n\n      match /tables/{tableId} {\n        allow read: if isStaff(rid) || restaurantAllowsPublicAccess(rid);\n\n        // Staff can do any write\n        allow write: if isStaff(rid);\n\n        // QR menu session open on empty table (boş -> aktif)\n        allow update: if restaurantAllowsPublicAccess(rid)\n          && resource.data.status == 'boş'\n          && request.resource.data.status == 'aktif'\n          && request.resource.data.sessionId is string\n          && request.resource.data.sessionId.size() > 0\n          && request.resource.data.diff(resource.data).affectedKeys()\n              .hasOnly(['status', 'sessionId', 'openedAt', 'updatedAt']);\n\n        // QR menu: update table status for call (aktif -> çağrı var, aktif -> hesap istendi)\n        allow update: if restaurantAllowsPublicAccess(rid)\n          && resource.data.status == 'aktif'\n          && request.resource.data.status in ['çağrı var', 'hesap istendi']\n          && request.resource.data.diff(resource.data).affectedKeys()\n              .hasOnly(['status', 'updatedAt']);\n\n        // QR menu: update table status for call from existing call states\n        allow update: if restaurantAllowsPublicAccess(rid)\n          && resource.data.status in ['çağrı var', 'hesap istendi']\n          && request.resource.data.status in ['çağrı var', 'hesap istendi']\n          && request.resource.data.diff(resource.data).affectedKeys()\n              .hasOnly(['status', 'updatedAt']);\n\n        // ── Shared Cart Items ─────────────────────────────────────────────────────\n        match /cartItems/{cartItemId} {\n          // Helper to get parent table data\n          function parentTable() {\n            return get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(tableId)).data;\n          }\n\n          function tableIsActive() {\n            return exists(/databases/$(database)/documents/restaurants/$(rid)/tables/$(tableId))\n              && parentTable().status in ['aktif', 'çağrı var', 'hesap istendi'];\n          }\n\n          // Staff can read/write all cart items\n          allow read, write: if isStaff(rid);\n\n          // Public can read cart items if restaurant allows and table is active\n          allow read: if restaurantAllowsPublicAccess(rid) && tableIsActive();\n\n          // Public can create cart items with valid data and matching session\n          allow create: if restaurantAllowsPublicAccess(rid)\n            && tableIsActive()\n            && request.resource.data.sessionId == parentTable().sessionId\n            && request.resource.data.customerId is string\n            && request.resource.data.customerId.size() > 0\n            && request.resource.data.customerName is string\n            && request.resource.data.productId is string\n            && request.resource.data.quantity is int\n            && request.resource.data.quantity > 0\n            && isNonNegativeNumber(request.resource.data.price);\n\n          // Public can update cart items (quantity changes)\n          allow update: if restaurantAllowsPublicAccess(rid)\n            && tableIsActive()\n            && request.resource.data.diff(resource.data).affectedKeys()\n                .hasOnly(['quantity', 'updatedAt']);\n\n          // Public can delete cart items\n          allow delete: if restaurantAllowsPublicAccess(rid) && tableIsActive();\n        }\n      }\n\n      // ── Calls (Waiter calls) ──────────────────────────────────────────────────\n\n      match /calls/{callId} {\n        // Staff can read all calls\n        allow read: if isStaff(rid);\n\n        // Public can read calls (for session status checking)\n        allow read: if restaurantAllowsPublicAccess(rid);\n\n        // Admin can manage all calls, waiters only their own accept/complete flow\n        allow create, update, delete: if isAdmin(rid);\n        allow update: if waiterCanAcceptCall(rid) || waiterCanCompleteOwnCall(rid) || waiterCanDeliverReadyOrder(rid);\n\n        // Waiter can create manual orders\n        allow create: if waiterCanCreateOrder(rid);\n\n        // QR menu: create new call with tip-specific restricted fields\n        allow create: if validPublicOrderCall(rid) || validPublicServiceCall(rid);\n      }\n\n      // ── Settings (menu, general) ───────────────────────────────────────────\n\n      match /settings/{settingId} {\n        // Public read for menu and general settings (QR menu needs logo/colors)\n        allow read: if isStaff(rid) || (\n          restaurantAllowsPublicAccess(rid)\n          && (settingId == 'menu' || settingId == 'general')\n        );\n        allow write: if isAdmin(rid);\n      }\n\n      // ── Audit Logs ────────────────────────────────────────────────────────────\n\n      match /auditLogs/{logId} {\n        // Only admin can read audit logs\n        allow read: if isAdmin(rid);\n\n        // Only authenticated staff can create logs (no public write)\n        allow create: if isStaff(rid)\n          && request.resource.data.actorId is string\n          && request.resource.data.actorName is string\n          && request.resource.data.actorRole in ['admin', 'waiter', 'super_admin']\n          && request.resource.data.action is string\n          && request.resource.data.targetPath is string;\n\n        // Audit logs cannot be updated or deleted\n        allow update, delete: if false;\n      }\n\n      // ── Ratings ───────────────────────────────────────────────────────────────\n\n      match /ratings/{ratingId} {\n        // Staff can read ratings\n        allow read: if isStaff(rid);\n\n        // Staff can do any write\n        allow write: if isAdmin(rid);\n\n        // Public rating create (QR menu customers, signed-in or not)\n        allow create: if restaurantAllowsPublicAccess(rid)\n          && request.resource.data.serviceRating is int\n          && request.resource.data.serviceRating >= 1\n          && request.resource.data.serviceRating <= 5\n          && request.resource.data.waiterRating is int\n          && request.resource.data.waiterRating >= 1\n          && request.resource.data.waiterRating <= 5\n          && request.resource.data.status in ['approved', 'suspicious']\n          && request.resource.data.comment is string\n          && request.resource.data.keys().hasAll(['restaurantId', 'tableId', 'tableNumber', 'sessionId', 'callId', 'waiterId', 'waiterName', 'serviceRating', 'waiterRating', 'comment', 'status', 'createdAt']);\n      }\n\n      // ── Loyalty Campaigns ─────────────────────────────────────────────────────\n\n      match /loyaltyCampaigns/{campaignId} {\n        // Staff can read all campaigns\n        allow read: if isStaff(rid);\n\n        // Public can read active campaigns only\n        allow read: if restaurantAllowsPublicAccess(rid)\n          && resource.data.active == true;\n\n        // Admin can manage campaigns\n        allow create, update, delete: if isAdmin(rid);\n      }\n\n      // ── Customers (Loyalty) ───────────────────────────────────────────────────\n\n      match /customers/{customerId} {\n        // Admin can read/write all customers\n        allow read, write: if isAdmin(rid);\n\n        // Waiter can read customers\n        allow read: if isWaiter(rid);\n\n        // Public can create customer record when registering for loyalty\n        allow create: if restaurantAllowsPublicAccess(rid)\n          && request.resource.data.name is string\n          && request.resource.data.phone is string\n          && request.resource.data.loyaltyEnabled == true\n          && request.resource.data.points == 0\n          && request.resource.data.totalOrders == 0\n          && request.resource.data.totalSpent == 0;\n\n        // Public can read own customer record by phone\n        allow read: if restaurantAllowsPublicAccess(rid);\n\n        // ── Customer Rewards ──────────────────────────────────────────────────\n\n        match /rewards/{rewardId} {\n          // Rewards are tenant-scoped and staff-only; public ownership cannot be\n          // verified safely from an unauthenticated QR session.\n          allow read: if isStaff(rid);\n          allow create, update: if isStaff(rid);\n          allow delete: if false;\n        }\n      }\n\n      // ── Loyalty Transactions ───────────────────────────────────────────────\n\n      match /loyaltyTransactions/{transactionId} {\n        allow read, create: if isStaff(rid);\n        allow update, delete: if false;\n      }\n    }\n\n    // ─── Deny all other access ──────────────────────────────────────────────────\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-07-06T09:59:43.591439Z","metadata":{"services":["cloud.firestore"]}}
