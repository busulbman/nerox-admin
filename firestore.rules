rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return signedIn() ? userDoc().role : null;
    }

    function userRestaurantId() {
      return signedIn() ? userDoc().restaurantId : null;
    }

    function isAdmin(rid) {
      return signedIn() && role() == 'admin' && userRestaurantId() == rid;
    }

    function isWaiter(rid) {
      return signedIn() && role() == 'waiter' && userRestaurantId() == rid;
    }

    function isStaff(rid) {
      return isAdmin(rid) || isWaiter(rid);
    }

    function restaurantPath(rid) {
      return /databases/$(database)/documents/restaurants/$(rid);
    }

    function restaurantExists(rid) {
      return exists(restaurantPath(rid));
    }

    function restaurantDoc(rid) {
      return get(restaurantPath(rid)).data;
    }

    function isRestaurantActive(rid) {
      let status = get(restaurantPath(rid)).data.status;
      return status == null || status == 'active';
    }

    function isSubscriptionValid(rid) {
      let data = get(restaurantPath(rid)).data;
      // If subscriptionExpiresAt field doesn't exist or is null, allow access
      let expires = data.subscriptionExpiresAt;
      return !('subscriptionExpiresAt' in data)
        || expires == null
        || (expires is timestamp && expires >= request.time)
        || (expires is int && expires >= request.time.toMillis());
    }

    function restaurantAllowsPublicAccess(rid) {
      return exists(restaurantPath(rid))
        && isRestaurantActive(rid)
        && isSubscriptionValid(rid);
    }

    function waiterCanAcceptCall(rid) {
      return isWaiter(rid)
        && resource.data.durum == 'bekliyor'
        && request.resource.data.durum == 'kabul edildi'
        && request.resource.data.status == 'accepted'
        && request.resource.data.waiterId == request.auth.uid
        && request.resource.data.waiterName is string
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['durum', 'status', 'waiterId', 'waiterName', 'acceptedAt']);
    }

    function waiterCanCompleteOwnCall(rid) {
      return isWaiter(rid)
        && resource.data.durum == 'kabul edildi'
        && resource.data.waiterId == request.auth.uid
        && request.resource.data.durum == 'tamamlandı'
        && request.resource.data.status == 'completed'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['durum', 'status', 'completedAt', 'resolvedAt', 'completedById', 'completedByName', 'completedByRole']);
    }

    function waiterCanCreateOrder(rid) {
      return isWaiter(rid)
        && request.resource.data.restaurantId == rid
        && request.resource.data.tip == 'sipariş'
        && request.resource.data.durum == 'kabul edildi'
        && request.resource.data.status == 'accepted'
        && request.resource.data.waiterId == request.auth.uid
        && request.resource.data.waiterName is string
        && request.resource.data.createdByRole == 'waiter'
        && request.resource.data.createdById == request.auth.uid
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && isNonNegativeNumber(request.resource.data.totalPrice);
    }

    function isNonNegativeNumber(value) {
      return (value is int || value is float) && value >= 0;
    }

    function publicCallTargetsLiveTableSession(rid) {
      return request.resource.data.restaurantId == rid
        && request.resource.data.tableId is string
        && request.resource.data.tableId.size() > 0
        && request.resource.data.tableNumber is int
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId.size() > 0
        && exists(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId))
        && get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId)).data.number == request.resource.data.tableNumber
        && get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId)).data.sessionId == request.resource.data.sessionId
        && get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(request.resource.data.tableId)).data.status in ['aktif', 'çağrı var', 'hesap istendi'];
    }

    function validPublicCallBase(rid) {
      return restaurantAllowsPublicAccess(rid)
        && publicCallTargetsLiveTableSession(rid)
        && request.resource.data.durum == 'bekliyor'
        && request.resource.data.status == 'open'
        && request.resource.data.waiterId == null
        && request.resource.data.waiterName == null
        && request.resource.data.note is string;
    }

    function validPublicOrderCall(rid) {
      return validPublicCallBase(rid)
        && request.resource.data.tip == 'sipariş'
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.groupedByCustomer is map
        && request.resource.data.groupedByCustomer.keys().size() > 0
        && isNonNegativeNumber(request.resource.data.totalPrice)
        && request.resource.data.keys().hasAll([
          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',
          'durum', 'status', 'customerName', 'createdAt', 'waiterId',
          'waiterName', 'note', 'items', 'totalPrice', 'groupedByCustomer'
        ])
        && request.resource.data.keys().hasOnly([
          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',
          'durum', 'status', 'customerName', 'createdAt', 'waiterId',
          'waiterName', 'note', 'items', 'totalPrice', 'groupedByCustomer'
        ]);
    }

    function validPublicServiceCall(rid) {
      return validPublicCallBase(rid)
        && request.resource.data.tip in ['yardım', 'hesap']
        && (request.resource.data.customerName == null || request.resource.data.customerName is string)
        && request.resource.data.keys().hasAll([
          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',
          'durum', 'status', 'customerName', 'createdAt', 'waiterId',
          'waiterName', 'note'
        ])
        && request.resource.data.keys().hasOnly([
          'tableId', 'tableNumber', 'sessionId', 'restaurantId', 'tip',
          'durum', 'status', 'customerName', 'createdAt', 'waiterId',
          'waiterName', 'note'
        ]);
    }

    function validPublicCustomerCreate(rid) {
      return restaurantAllowsPublicAccess(rid)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && (
          !('email' in request.resource.data)
          || request.resource.data.email == null
          || request.resource.data.email is string
        )
        && request.resource.data.loyaltyEnabled == true
        && request.resource.data.points == 0
        && request.resource.data.totalOrders == 0
        && request.resource.data.totalSpent == 0
        && request.resource.data.keys().hasAll([
          'name', 'phone', 'loyaltyEnabled', 'points', 'totalOrders',
          'totalSpent', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'name', 'phone', 'email', 'loyaltyEnabled', 'points', 'totalOrders',
          'totalSpent', 'createdAt', 'updatedAt'
        ]);
    }

    // ─── Users collection ───────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can read their own profile
      allow read: if signedIn() && request.auth.uid == uid;

      // Admin can read/write users in their restaurant
      allow read: if signedIn() && isAdmin(resource.data.restaurantId);
      allow write: if signedIn() && isAdmin(request.resource.data.restaurantId);

      // Waiters can read active waiter leaderboard entries from their restaurant
      allow read: if signedIn()
        && role() == 'waiter'
        && resource.data.role == 'waiter'
        && resource.data.active == true
        && resource.data.restaurantId == userRestaurantId();

      // Allow user to update their own presence fields
      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isOnline', 'lastSeen']);

      // Allow waiter to increment only their own completed call counter
      allow update: if signedIn()
        && request.auth.uid == uid
        && role() == 'waiter'
        && resource.data.role == 'waiter'
        && resource.data.restaurantId == userRestaurantId()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['totalCalls'])
        && request.resource.data.totalCalls is int
        && request.resource.data.totalCalls == ((resource.data.totalCalls is int ? resource.data.totalCalls : 0) + 1);
    }

    // ─── Restaurant data ────────────────────────────────────────────────────────

    match /restaurants/{rid} {
      allow get, list: if isStaff(rid);
      allow create: if isAdmin(rid);
      allow update: if isAdmin(rid);
      allow delete: if isAdmin(rid);

      // ── Categories & Products (Menu) ──────────────────────────────────────────

      match /categories/{catId} {
        // Staff can always read their own menu
        allow read: if isStaff(rid) || restaurantAllowsPublicAccess(rid);
        // Only admin can modify
        allow write: if isAdmin(rid);
      }

      match /products/{prodId} {
        // Staff can always read their own menu
        allow read: if isStaff(rid) || restaurantAllowsPublicAccess(rid);
        // Only admin can modify
        allow write: if isAdmin(rid);
      }

      // ── Loyalty Campaigns ─────────────────────────────────────────────────────

      match /loyaltyCampaigns/{campaignId} {
        allow read: if isAdmin(rid) || (
          restaurantAllowsPublicAccess(rid)
          && resource.data.active == true
        );
        allow write: if isAdmin(rid);
      }

      // ── Customers ─────────────────────────────────────────────────────────────

      match /customers/{customerId} {
        allow read: if isAdmin(rid);
        allow write: if isAdmin(rid);
        allow create: if validPublicCustomerCreate(rid);
      }

      // ── Tables ────────────────────────────────────────────────────────────────

      match /tables/{tableId} {
        allow read: if isStaff(rid) || restaurantAllowsPublicAccess(rid);

        // Staff can do any write
        allow write: if isStaff(rid);

        // QR menu session open on empty table (boş -> aktif)
        allow update: if restaurantAllowsPublicAccess(rid)
          && resource.data.status == 'boş'
          && request.resource.data.status == 'aktif'
          && request.resource.data.sessionId is string
          && request.resource.data.sessionId.size() > 0
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'sessionId', 'openedAt', 'updatedAt']);

        // QR menu: update table status for call (aktif -> çağrı var, aktif -> hesap istendi)
        allow update: if restaurantAllowsPublicAccess(rid)
          && resource.data.status == 'aktif'
          && request.resource.data.status in ['çağrı var', 'hesap istendi']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt']);

        // QR menu: update table status for call from existing call states
        allow update: if restaurantAllowsPublicAccess(rid)
          && resource.data.status in ['çağrı var', 'hesap istendi']
          && request.resource.data.status in ['çağrı var', 'hesap istendi']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt']);

        // ── Shared Cart Items ─────────────────────────────────────────────────────
        match /cartItems/{cartItemId} {
          // Helper to get parent table data
          function parentTable() {
            return get(/databases/$(database)/documents/restaurants/$(rid)/tables/$(tableId)).data;
          }

          function tableIsActive() {
            return exists(/databases/$(database)/documents/restaurants/$(rid)/tables/$(tableId))
              && parentTable().status in ['aktif', 'çağrı var', 'hesap istendi'];
          }

          // Staff can read/write all cart items
          allow read, write: if isStaff(rid);

          // Public can read cart items if restaurant allows and table is active
          allow read: if restaurantAllowsPublicAccess(rid) && tableIsActive();

          // Public can create cart items with valid data and matching session
          allow create: if restaurantAllowsPublicAccess(rid)
            && tableIsActive()
            && request.resource.data.sessionId == parentTable().sessionId
            && request.resource.data.customerId is string
            && request.resource.data.customerId.size() > 0
            && request.resource.data.customerName is string
            && request.resource.data.productId is string
            && request.resource.data.quantity is int
            && request.resource.data.quantity > 0
            && isNonNegativeNumber(request.resource.data.price);

          // Public can update cart items (quantity changes)
          allow update: if restaurantAllowsPublicAccess(rid)
            && tableIsActive()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['quantity', 'updatedAt']);

          // Public can delete cart items
          allow delete: if restaurantAllowsPublicAccess(rid) && tableIsActive();
        }
      }

      // ── Calls (Waiter calls) ──────────────────────────────────────────────────

      match /calls/{callId} {
        // Staff can read all calls
        allow read: if isStaff(rid);

        // Public can read calls (for session status checking)
        allow read: if restaurantAllowsPublicAccess(rid);

        // Admin can manage all calls, waiters only their own accept/complete flow
        allow create, update, delete: if isAdmin(rid);
        allow update: if waiterCanAcceptCall(rid) || waiterCanCompleteOwnCall(rid);

        // Waiter can create manual orders
        allow create: if waiterCanCreateOrder(rid);

        // QR menu: create new call with tip-specific restricted fields
        allow create: if validPublicOrderCall(rid) || validPublicServiceCall(rid);
      }

      // ── Settings (menu, general) ───────────────────────────────────────────

      match /settings/{settingId} {
        // Public read for menu and general settings (QR menu needs logo/colors)
        allow read: if isStaff(rid) || (
          restaurantAllowsPublicAccess(rid)
          && (settingId == 'menu' || settingId == 'general')
        );
        allow write: if isAdmin(rid);
      }

      // ── Ratings ───────────────────────────────────────────────────────────────

      match /ratings/{ratingId} {
        // Staff can read ratings
        allow read: if isStaff(rid);

        // Staff can do any write
        allow write: if isAdmin(rid);

        // Public rating create (QR menu customers, signed-in or not)
        allow create: if restaurantAllowsPublicAccess(rid)
          && request.resource.data.serviceRating is int
          && request.resource.data.serviceRating >= 1
          && request.resource.data.serviceRating <= 5
          && request.resource.data.waiterRating is int
          && request.resource.data.waiterRating >= 1
          && request.resource.data.waiterRating <= 5
          && request.resource.data.status in ['approved', 'suspicious']
          && request.resource.data.comment is string
          && request.resource.data.keys().hasAll(['restaurantId', 'tableId', 'tableNumber', 'sessionId', 'callId', 'waiterId', 'waiterName', 'serviceRating', 'waiterRating', 'comment', 'status', 'createdAt']);
      }

      // ── Loyalty Campaigns ─────────────────────────────────────────────────────

      match /loyaltyCampaigns/{campaignId} {
        // Staff can read all campaigns
        allow read: if isStaff(rid);

        // Public can read active campaigns only
        allow read: if restaurantAllowsPublicAccess(rid)
          && resource.data.active == true;

        // Admin can manage campaigns
        allow create, update, delete: if isAdmin(rid);
      }

      // ── Customers (Loyalty) ───────────────────────────────────────────────────

      match /customers/{customerId} {
        // Admin can read/write all customers
        allow read, write: if isAdmin(rid);

        // Waiter can read customers
        allow read: if isWaiter(rid);

        // Public can create customer record when registering for loyalty
        allow create: if restaurantAllowsPublicAccess(rid)
          && request.resource.data.name is string
          && request.resource.data.phone is string
          && request.resource.data.loyaltyEnabled == true
          && request.resource.data.points == 0
          && request.resource.data.totalOrders == 0
          && request.resource.data.totalSpent == 0;

        // Public can read own customer record by phone
        allow read: if restaurantAllowsPublicAccess(rid);
      }
    }

    // ─── Deny all other access ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
