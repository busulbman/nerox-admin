{
  "rules": {
    "presence": {
      "$restaurantId": {
        "waiters": {
          ".read": "auth != null",
          ".write": false,
          "$waiterId": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid == $waiterId"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
